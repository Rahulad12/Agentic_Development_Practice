# Environment Variables for AMNIL Research Claude Frontend

# ============================================================================
# API Configuration
# ============================================================================

# Backend API base URL
# Default: https://localhost:44300 (dev) or https://api.example.com (prod)
VITE_API_BASE_URL=https://localhost:44300

# API request timeout in milliseconds
# Default: 30000 (30 seconds)
VITE_API_TIMEOUT=30000

# ============================================================================
# Application Configuration
# ============================================================================

# Application name
# Default: AMNIL Research Claude
VITE_APP_NAME=AMNIL Research Claude

# Application version
# Default: 0.1.0
VITE_APP_VERSION=0.1.0

# ============================================================================
# Analytics Configuration
# ============================================================================

# Enable analytics tracking
# Default: false
VITE_ANALYTICS_ENABLED=false

# Analytics ID (e.g., Google Analytics ID)
# Default: empty string
VITE_ANALYTICS_ID=

# ============================================================================
# Feature Flags
# ============================================================================

# Enable React Query DevTools
# Default: true in development, false in production
VITE_ENABLE_DEV_TOOLS=true

# Enable console logging
# Default: true in development, false in production
VITE_ENABLE_LOGGING=true
